        ('WS','/workspaces/{id}/sync',

         'Yjs WebSocket sync protocol',

         'Bidirectional — sync document edits, cursor positions, highlights in real time'),

        ('POST','/workspaces/{id}/highlights',

         '{ start_offset, end_offset, color, label? }',

         '200: { highlight_id }  — persist a highlight'),

        ('POST','/workspaces/{id}/comments',

