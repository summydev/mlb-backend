def S():

    return {

        'h1':    ParagraphStyle('h1',fontName='Helvetica-Bold',fontSize=15,

                     textColor=INDIGO,leading=19,spaceBefore=14,spaceAfter=6),

        'h2':    ParagraphStyle('h2',fontName='Helvetica-Bold',fontSize=11,

                     textColor=INDIGO_MID,leading=14,spaceBefore=10,spaceAfter=4),

        'h3':    ParagraphStyle('h3',fontName='Helvetica-Bold',fontSize=9.5,

                     textColor=TEXT_DARK,leading=13,spaceBefore=6,spaceAfter=3),

        'body':  ParagraphStyle('body',fontName='Helvetica',fontSize=9,

                     textColor=TEXT_MED,leading=14,spaceAfter=4),

        'small': ParagraphStyle('sm',fontName='Helvetica',fontSize=8,

                     textColor=TEXT_LIGHT,leading=12,spaceAfter=3),

        'bullet':ParagraphStyle('bul',fontName='Helvetica',fontSize=9,

                     textColor=TEXT_MED,leading=13,leftIndent=12,spaceAfter=3,

                     bulletIndent=3),

        'sub':   ParagraphStyle('sub',fontName='Helvetica',fontSize=8.5,

                     textColor=TEXT_LIGHT,leading=12,leftIndent=24,spaceAfter=2,

                     bulletIndent=15),

        'th':    ParagraphStyle('th',fontName='Helvetica-Bold',fontSize=8.5,

                     textColor=WHITE,leading=11),

        'td':    ParagraphStyle('td',fontName='Helvetica',fontSize=8.5,

                     textColor=TEXT_MED,leading=12),

        'tdb':   ParagraphStyle('tdb',fontName='Helvetica-Bold',fontSize=8.5,

                     textColor=TEXT_DARK,leading=12),

        'code':  ParagraphStyle('code',fontName='Courier',fontSize=8,

                     textColor=INDIGO,leading=13,backColor=LIGHT_CARD,

                     leftIndent=8,rightIndent=8,spaceAfter=4),

        'cover_t':ParagraphStyle('ct',fontName='Helvetica-Bold',fontSize=32,

                     textColor=WHITE,leading=36,spaceAfter=6),

        'cover_s':ParagraphStyle('cs',fontName='Helvetica',fontSize=13,

                     textColor=HexColor('#C8C4E8'),leading=18,spaceAfter=4),

    }





def bt(rows,widths,hbg=INDIGO):

    t=Table(rows,colWidths=widths)

    t.setStyle(TableStyle([

        ('BACKGROUND',(0,0),(-1,0),hbg),

        ('ROWBACKGROUNDS',(0,1),(-1,-1),[WHITE,LIGHT_BG]),

        ('TOPPADDING',(0,0),(-1,-1),6),('BOTTOMPADDING',(0,0),(-1,-1),6),

        ('LEFTPADDING',(0,0),(-1,-1),8),('RIGHTPADDING',(0,0),(-1,-1),6),

        ('LINEBELOW',(0,0),(-1,-1),0.4,BORDER),

        ('VALIGN',(0,0),(-1,-1),'TOP'),

    ]))

    return t



def api_t(rows,st):

    data=[[Paragraph(h,st['th']) for h in ['Method','Endpoint','Payload / Params','Response']]]

    for m,e,p,r in rows:

        data.append([Paragraph(m,st['tdb']),Paragraph(e,st['td']),

                     Paragraph(p,st['td']),Paragraph(r,st['td'])])

    return bt(data,[16*mm,46*mm,68*mm,30*mm])



def state_t(rows,st):

    data=[[Paragraph(h,st['th']) for h in ['State / Condition','UI behaviour','Dev note']]]

    for s,u,d in rows:

        data.append([Paragraph(s,st['tdb']),Paragraph(u,st['td']),Paragraph(d,st['td'])])

    return bt(data,[38*mm,74*mm,48*mm])



def b(t,st): return Paragraph(f'<bullet>\u2022</bullet>{t}',st['bullet'])

def sb(t,st): return Paragraph(f'<bullet>  \u2013</bullet>{t}',st['sub'])





# ─────────────────────────────────────────────────────────────

# PAGE TEMPLATES

# ─────────────────────────────────────────────────────────────

def cover_bg(canvas,doc):

    canvas.saveState()

    canvas.setFillColor(INK); canvas.rect(0,0,W,H,fill=1,stroke=0)

    canvas.setFillColor(INDIGO); canvas.circle(W+60,H+40,220,fill=1,stroke=0)

    canvas.setFillColor(INDIGO_MID); canvas.circle(-30,-20,160,fill=1,stroke=0)

    canvas.setFillColor(SKY); canvas.circle(W*0.3,H*0.15,80,fill=1,stroke=0)

    canvas.setFillColor(HexColor('#0E0A2E90'))

    canvas.circle(W*0.3,H*0.15,80,fill=1,stroke=0)

    canvas.setFillColor(VOLT); canvas.rect(0,H-5,W,5,fill=1,stroke=0)

    canvas.setFillColor(INDIGO_MID); canvas.rect(0,0,W,32,fill=1,stroke=0)

    canvas.setFillColor(MUTED); canvas.setFont('Helvetica',7.5)

    canvas.drawString(20*mm,12,

        f"myLB  |  Community Tab — Developer Handoff  |  {datetime.date.today().strftime('%d %B %Y')}")

    canvas.drawRightString(W-20*mm,12,'CONFIDENTIAL  |  v1.0')

    canvas.restoreState()





def inner_bg(canvas,doc):

    canvas.saveState()

    canvas.setFillColor(HexColor('#FAFAF8')); canvas.rect(0,0,W,H,fill=1,stroke=0)

    canvas.setFillColor(INDIGO); canvas.rect(0,H-18,W,18,fill=1,stroke=0)

    canvas.setFillColor(SKY); canvas.rect(0,H-21,50,3,fill=1,stroke=0)

    canvas.setFillColor(WHITE); canvas.setFont('Helvetica-Bold',7.5)

    canvas.drawString(20*mm,H-13,

        'myLB — Community Tab Developer Handoff  (⊕ Community)')

    canvas.setFont('Helvetica',7.5); canvas.setFillColor(HexColor('#C8C4E8'))

    canvas.drawRightString(W-20*mm,H-13,f'v1.0  |  {datetime.date.today().strftime("%B %Y")}')

    canvas.setFillColor(BORDER); canvas.rect(20*mm,18,W-40*mm,0.4,fill=1,stroke=0)

    canvas.setFillColor(TEXT_LIGHT); canvas.setFont('Helvetica',7.5)

    canvas.drawString(20*mm,8,'Confidential — Internal use only')

    canvas.drawRightString(W-20*mm,8,f'Page {doc.page}')

    canvas.restoreState()





def page_bg(canvas,doc):

    cover_bg(canvas,doc) if doc.page==1 else inner_bg(canvas,doc)





# ═════════════════════════════════════════════════════════════

def build():

    out='/mnt/user-data/outputs/myLB_CommunityTab_DevHandoff.pdf'

    doc=SimpleDocTemplate(out,pagesize=A4,

        leftMargin=20*mm,rightMargin=20*mm,

        topMargin=26*mm,bottomMargin=24*mm,

        title='myLB – Community Tab Developer Handoff')

    st=S(); story=[]



    # ── COVER ─────────────────────────────────────────────────

    story+=[Spacer(1,48*mm)]

    story+=[Paragraph('my<font color="#C8F53C">LB</font>',st['cover_t'])]

    story+=[Paragraph('Community Tab — Full Developer Handoff',st['cover_s'])]

    story+=[Paragraph('⊕  Co-op Quest Board  ·  Discover Feed  ·  Study Groups  ·  Live Workspace',st['cover_s'])]

    story+=[Spacer(1,10)]

    acc=Table([['','']],colWidths=[28*mm,W-40*mm-28*mm])

    acc.setStyle(TableStyle([

        ('BACKGROUND',(0,0),(0,0),SKY),('BACKGROUND',(1,0),(1,0),INDIGO_MID),

        ('ROWHEIGHT',(0,0),(-1,-1),3),

        ('TOPPADDING',(0,0),(-1,-1),0),('BOTTOMPADDING',(0,0),(-1,-1),0),

        ('LEFTPADDING',(0,0),(-1,-1),0),('RIGHTPADDING',(0,0),(-1,-1),0),

    ]))

    story+=[acc,Spacer(1,14)]

    meta=[

        ['Document type',  'Developer Handoff — Community Tab complete specification'],

        ['Prerequisites',  'Onboarding · Home Tab · Nav Bar · Canvas Tab · Study Tab handoffs done'],

        ['Screens covered','Community root (tab nav) · Co-op Quest Board (8) · Discover Feed · Study Groups · Live Collaborative Workspace · Quest Detail'],

        ['Key feature',    'This is the social/multiplayer hub. Real-time database required for live quest progress, cursor sync, and leaderboard updates.'],

        ['Platform',       'iOS (primary) · Android parity · Dark mode'],

        ['Version',        f"v1.0  —  {datetime.date.today().strftime('%d %B %Y')}"],

    ]

    mt=Table(meta,colWidths=[44*mm,116*mm])

    mt.setStyle(TableStyle([

        ('FONTNAME',(0,0),(0,-1),'Helvetica-Bold'),('FONTSIZE',(0,0),(-1,-1),9),

        ('TEXTCOLOR',(0,0),(0,-1),MUTED),('TEXTCOLOR',(1,0),(1,-1),WHITE),

        ('TOPPADDING',(0,0),(-1,-1),5),('BOTTOMPADDING',(0,0),(-1,-1),5),

        ('LINEBELOW',(0,0),(-1,-2),0.3,HexColor('#2D2060')),

    ]))

    story+=[mt,PageBreak()]



    # ════════════════════════════════════════════════════════

    # PAGE 2 — OVERVIEW

    # ════════════════════════════════════════════════════════

    story+=[SectionBanner('Overview','What the Community tab contains and how it is structured')]

    story+=[Spacer(1,8)]

    story+=[Paragraph('The Community tab is the social engine of myLB',st['h1'])]

    story+=[Paragraph(

        'The Community tab (⊕) is where studying becomes a team sport. '

        'It has four interconnected areas: the Co-op Quest Board (the multiplayer game lobby), '

        'the Discover Feed (public study sets from the community), '

        'Study Groups (creating and managing your group), and the Live Collaborative Workspace '

        '(real-time shared notes with live cursors). '

        'Real-time data is at the core of this tab — it requires a real-time database '

        '(Firebase Realtime DB or Supabase Realtime) for live updates.',

        st['body'])]

    story+=[Spacer(1,8)]

    story+=[NoticeBox(

        'REAL-TIME REQUIREMENT: Quest progress bars, leaderboard positions, and live workspace '

        'cursors all update in real time. Use WebSocket connections (Firebase / Supabase Realtime) '

        'for these features — polling is NOT sufficient.',

        WARN_BG,WARN_BD,'CRITICAL')]

    story+=[Spacer(1,10)]



    story+=[Paragraph('Community tab — complete screen map',st['h2'])]

    smap=[

        [Paragraph('Screen',st['th']),Paragraph('ID',st['th']),

         Paragraph('Route',st['th']),Paragraph('Entry point',st['th']),

         Paragraph('Nav bar',st['th'])],

        [Paragraph('Community root\n(Quest Board)',st['tdb']),Paragraph('8',st['td']),

         Paragraph('/community',st['td']),

         Paragraph('Nav bar Community tap. Default view: Quest Board.',st['td']),

         Paragraph('Community active',st['td'])],

        [Paragraph('Quest Detail',st['tdb']),Paragraph('QD',st['td']),

         Paragraph('/community/quests/{id}',st['td']),

         Paragraph('Tap a quest card on the Quest Board.',st['td']),

         Paragraph('Community active',st['td'])],

        [Paragraph('Discover Feed',st['tdb']),Paragraph('DF',st['td']),

         Paragraph('/community/discover',st['td']),

         Paragraph('Tap "Discover" tab in Community segmented nav.',st['td']),

         Paragraph('Community active',st['td'])],

        [Paragraph('Study Groups',st['tdb']),Paragraph('SG',st['td']),

         Paragraph('/community/groups',st['td']),

         Paragraph('Tap "Groups" tab in Community segmented nav.',st['td']),

         Paragraph('Community active',st['td'])],

        [Paragraph('Group Detail',st['tdb']),Paragraph('GD',st['td']),

