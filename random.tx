VOLT       = HexColor('#C8F53C')

SKY        = HexColor('#5ECEFF')

MINT       = HexColor('#3CFFC8')

PEACH      = HexColor('#FF8A65')

MUTED      = HexColor('#8B85A8')

WHITE      = HexColor('#FFFFFF')

LIGHT_BG   = HexColor('#F4F2FF')

LIGHT_CARD = HexColor('#ECEAF8')

