        st['small'])]

    story+=[Spacer(1,10)]



    story+=[SectionBanner('8.1  Data Requirements',color=INDIGO_MID)]

    story+=[Spacer(1,6)]

    story+=[api_t([

        ('GET','/users/me/quests',

         '?status=active|completed&page={n}&limit=10',

         '200: { quests[], total_count }'),

        ('GET','/quests/{id}',

         'Authorization: Bearer {token}',

         '200: { quest_id, title, description, target, progress, deadline, members[], leaderboard[] }'),

        ('POST','/quests/{id}/contribute',

         '{ xp_amount, session_id }',

         '200: { new_progress, new_rank, xp_earned }  — called after each study session'),

        ('GET','/quests/{id}/leaderboard',

         'Real-time subscription (WebSocket)',

         'Stream: { leaderboard[] } — updates live as members contribute'),

    ],st)]

    story+=[Spacer(1,6)]



    quest_obj=[

        [Paragraph('Field',st['th']),Paragraph('Type',st['th']),Paragraph('Description',st['th'])],

