         Paragraph('"+ Join or Create a Study Group" button on Quest Board.',st['td']),

         Paragraph('Community active',st['td'])],

    ]

    story+=[bt(smap,[30*mm,10*mm,38*mm,60*mm,22*mm]),Spacer(1,10)]



    story+=[Paragraph('Community tab — internal navigation structure',st['h2'])]

    story+=[Paragraph(

        'The Community tab root (Screen 8) has a 3-segment navigation bar at the top: '

        '"Quests" | "Discover" | "Groups". Each segment shows a different content area. '

        'This is an in-tab toggle — no page push. '

        'Tapping the Community tab from the bottom nav bar always goes to the "Quests" segment.',

        st['body'])]

    story+=[Spacer(1,6)]

    seg_spec=[

        [Paragraph('Segment',st['th']),Paragraph('Content',st['th']),

