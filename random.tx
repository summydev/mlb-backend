    ]

    story+=[bt(seg_spec,[28*mm,90*mm,18*mm,24*mm]),PageBreak()]



    # ════════════════════════════════════════════════════════

    # PAGE 3 — SCREEN 8: CO-OP QUEST BOARD

    # ════════════════════════════════════════════════════════

    story+=[ScreenBlock('8','Co-op Quest Board','/community',

            'Community tab active (Tab 3)',INDIGO)]

    story+=[Spacer(1,8)]

    story+=[Paragraph('Purpose',st['h2'])]

    story+=[Paragraph(

        'The Quest Board is the multiplayer game lobby of myLB. '

        'It shows the user\'s active and completed group challenges, '

        'live group progress, a leaderboard, and the gateway to creating '

        'or joining study groups. It should feel energetic and competitive — '

        'like opening a multiplayer lobby.',

        st['body'])]

    story+=[Spacer(1,8)]



    story+=[Paragraph('Co-op Quest Board visual',st['h2'])]

    story+=[Spacer(1,4)]

    story+=[QuestBoardMockup()]

    story+=[Spacer(1,4)]

    story+=[Paragraph(

        'Above: Quest Board showing segmented nav, featured hero quest card with thick '

