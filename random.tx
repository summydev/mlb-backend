         Paragraph('Community active',st['td'])],

        [Paragraph('Live Workspace',st['tdb']),Paragraph('LW',st['td']),

         Paragraph('/community/workspace/{id}',st['td']),

         Paragraph('"Open Workspace" from Group Detail or Quest Detail.',st['td']),

