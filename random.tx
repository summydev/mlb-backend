        [Paragraph('type',st['tdb']),Paragraph('enum',st['td']),Paragraph('coop | solo',st['td'])],

        [Paragraph('target',st['tdb']),Paragraph('integer',st['td']),Paragraph('Goal number (e.g. 500 terms)',st['td'])],

