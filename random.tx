    story+=[ComponentLabel('Component B: Featured Quest card (hero)',HexColor('#0F5070'))]

    story+=[Spacer(1,4)]

    hero_quest=[

        [Paragraph('Element',st['th']),Paragraph('Specification',st['th'])],

