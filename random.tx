    story+=[ScreenBlock('LW','Live Collaborative Workspace','/community/workspace/{id}',

            'Community tab active (Tab 3)',HexColor('#0F5070'))]

    story+=[Spacer(1,8)]

    story+=[Paragraph('Purpose',st['h2'])]

    story+=[Paragraph(

        'The Live Workspace is a shared document where group members can write, '

        'annotate, and highlight notes together in real time. It shows live cursors '

        'for each active member, colour-coded highlights, and a live contribution '

        'progress bar that feeds directly into the active co-op quest. '

        'This requires a real-time collaborative editing engine.',

        st['body'])]

    story+=[Spacer(1,8)]

    story+=[NoticeBox(

        'Real-time CRDT (Conflict-free Replicated Data Type) required for collaborative text editing. '

        'Use Yjs + a WebSocket provider (y-websocket / Supabase Realtime). '

        'DO NOT use last-write-wins — concurrent edits must merge gracefully.',

        WARN_BG,WARN_BD,'TECHNICAL REQUIREMENT')]

    story+=[Spacer(1,10)]



    story+=[SectionBanner('LW.1  Data Requirements',color=INDIGO_MID)]

    story+=[Spacer(1,6)]

