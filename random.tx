class ScreenBlock(Flowable):

    def __init__(self, sid, name, route, nav_note, color=INDIGO_MID):

        super().__init__()

        self.sid=sid; self.name=name; self.route=route

        self.nav=nav_note; self.color=color; self.width=W-40*mm



    def wrap(self,*args): return self.width, 50



    def draw(self):

        c=self.canv

        c.setFillColor(self.color)

        c.roundRect(0,2,self.width,46,8,fill=1,stroke=0)

        tc=WHITE if self.color not in (VOLT,MINT,SKY) else INK

        c.setFillColor(tc)

        c.setFont('Helvetica-Bold',8); c.drawString(12,38,f'SCREEN  {self.sid}')

        c.setFont('Helvetica-Bold',14); c.drawString(12,18,self.name)

        c.setFont('Helvetica',8); c.drawRightString(self.width-12,38,f'Route: {self.route}')

        pc=VOLT if self.color==INDIGO_MID else HexColor('#2D2090')

        ptc=INK if pc==VOLT else WHITE

        c.setFillColor(pc); c.roundRect(self.width-174,8,162,18,9,fill=1,stroke=0)

        c.setFillColor(ptc); c.setFont('Helvetica-Bold',7.5)

        c.drawCentredString(self.width-93,14.5,self.nav)





class SectionBanner(Flowable):

    def __init__(self,title,subtitle='',color=INDIGO):

        super().__init__()

        self.title=title; self.subtitle=subtitle

        self.color=color; self.width=W-40*mm



    def wrap(self,*args): return self.width, 38



    def draw(self):

        c=self.canv

        c.setFillColor(self.color); c.rect(0,2,self.width,32,fill=1,stroke=0)

        c.setFillColor(VOLT); c.rect(0,2,4,32,fill=1,stroke=0)

        c.setFillColor(WHITE); c.setFont('Helvetica-Bold',10.5)

        c.drawString(14,21,self.title.upper())

        if self.subtitle:

            c.setFont('Helvetica',8); c.setFillColor(HexColor('#C8C4E8'))

            c.drawString(14,8,self.subtitle)





class NoticeBox(Flowable):

    def __init__(self,text,bg,bd,icon='',height=36):

        super().__init__()

        self.text=text; self.bg=bg; self.bd=bd

        self.icon=icon; self._h=height; self.width=W-40*mm



    def wrap(self,*args): return self.width, self._h



    def draw(self):

        c=self.canv

        c.setFillColor(self.bg); c.roundRect(0,0,self.width,self._h-2,6,fill=1,stroke=0)

        c.setStrokeColor(self.bd); c.setLineWidth(1)

        c.roundRect(0,0,self.width,self._h-2,6,fill=0,stroke=1)

        c.setStrokeColor(self.bd); c.setLineWidth(2.5); c.line(0,0,0,self._h-2)

        c.setFillColor(TEXT_DARK); c.setFont('Helvetica',8.5)

        c.drawString(10,11,(self.icon+'  ' if self.icon else '')+self.text)





class ComponentLabel(Flowable):

    def __init__(self,text,color=INDIGO_MID):

        super().__init__()

        self.text=text; self.color=color; self.width=W-40*mm



    def wrap(self,*args): return self.width, 22



    def draw(self):

        c=self.canv

        tw=len(self.text)*6.2+18

        c.setFillColor(self.color); c.roundRect(0,2,tw,18,5,fill=1,stroke=0)

        fc=INK if self.color in (VOLT,MINT,SKY) else WHITE

        c.setFillColor(fc); c.setFont('Helvetica-Bold',8)

        c.drawString(9,8,self.text.upper())





